{
  "name": "mini-apps",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "dev:punta-cana": "turbo run dev --filter=@mini-apps/punta-cana",
